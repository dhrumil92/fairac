# Server
PORT=5000
NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=fairac_db
DB_USER=postgres
DB_PASSWORD=YOUR_DB_PASSWORD_HERE

# JWT
JWT_SECRET=YOUR_STRONG_RANDOM_SECRET_HERE_MIN_32_CHARS
JWT_EXPIRES_IN=7d

# bcrypt
BCRYPT_SALT_ROUNDS=10

# CORS (production URL of your hosted frontend, e.g. Oracle Cloud / web app)
FRONTEND_URL=https://your-frontend-domain.com

# --- Script-only variables (not used by the server itself) ---
# Used ONLY when running: node scripts/migration_super_admin.js
SUPER_ADMIN_PASSWORD=YOUR_SUPER_ADMIN_PASSWORD_HERE
# Used ONLY when running: node scripts/set_admin_password.js
ADMIN_PASSWORD=YOUR_ADMIN_PASSWORD_HERE
